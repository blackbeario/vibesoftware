---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Message Sent — Vibe Software">
  <section class="thank-you">
    <h1>Thanks for reaching out!</h1>
    <p>We've received your message and will get back to you within a business day.</p>
    <a href="/" class="btn btn-primary">&larr; Back to Home</a>
  </section>
</BaseLayout>

<style>
  .thank-you {
    max-width: 600px;
    margin: 0 auto;
    padding: 10rem 1.5rem 6rem;
    text-align: center;
  }
  .thank-you h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  .thank-you p {
    color: var(--muted);
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }
</style>
